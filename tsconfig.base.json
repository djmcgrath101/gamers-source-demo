{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@gamers-source/angular-plugin": ["./tools/angular/plugin/src/index.ts"],
      "@gamers-source/angular-tools-utils": ["./tools/angular/utils/src/index.ts"],
      "@gamers-source/nx-plugin": ["./tools/nx/plugin/src/index.ts"],
      "@gamers-source/nx-types": ["./tools/nx/types/src/index.ts"],
      "@gamers-source/nx-utils": ["./tools/nx/utils/src/index.ts"],
      "@gamers-source/shared-angular-data-access": [
        "./libs/shared/angular/data-access/src/index.ts"
      ],
      "@gamers-source/shared-angular-testing": ["./libs/shared/angular/testing/src/index.ts"],
      "@gamers-source/shared-angular-utils": ["./libs/shared/angular/utils/src/index.ts"],
      "@gamers-source/shared-material-types": ["./libs/shared/material/types/src/index.ts"],
      "@gamers-source/shared-material-ui": ["./libs/shared/material/ui/src/index.ts"],
      "@gamers-source/shared-types": ["./libs/shared/types/src/index.ts"],
      "@gamers-source/shared-utils": ["./libs/shared/utils/src/index.ts"],
      "@gamers-source/ts-plugin": ["./tools/ts/plugin/src/index.ts"],
      "@gamers-source/ts-utils": ["./tools/ts/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
