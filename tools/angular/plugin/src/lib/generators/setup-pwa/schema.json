{
  "$schema": "https://json-schema.org/schema",
  "$id": "SetupPwaGeneratorSchema",
  "title": "Setup PWA Generator Schema",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "Name of the project to set up as a PWA.",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "skipFormat": {
      "description": "Skip formatting files",
      "type": "boolean",
      "default": false
    }
  },
  "required": ["project"]
}
